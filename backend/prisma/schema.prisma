datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  FINANCE
}

enum VendorUserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum VendorOnboardingStatus {
  SHELL_CREATED
  INVITED
  ACTIVE
  SUSPENDED
}

enum ModerationStatus {
  DRAFT
  PUBLISHED
  SUSPENDED
}

enum VendorFulfillmentType {
  EMAIL
  API
  DIGITAL
}

enum VendorStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum CampaignMode {
  SINGLE
  CHOICE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RecipientStatus {
  INVITED
  VIEWED
  REDEEMED
  OPTED_OUT
  BOUNCED
  REMOVED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SENT_TO_VENDOR
  SHIPPED
  DELIVERED
  EXCEPTION
  CANCELLED
}

enum LedgerEntryType {
  TOPUP
  HOLD
  HOLD_RELEASE
  CHARGE
  REFUND
  ADJUSTMENT
}

enum PaymentProvider {
  RAZORPAY
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  SENT
  BOUNCED
  FAILED
}

model Organization {
  id               String   @id @default(uuid())
  name             String
  gstin            String
  stateCode        String
  settings         Json     @default("{}")
  brandingDefaults Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            Membership[]
  campaigns        Campaign[]
  orders           Order[]
  wallet           Wallet?
  payments         Payment[]
  proformaInvoices ProformaInvoice[]
  invoices         Invoice[]
  auditLogs        AuditLog[]
  recipientImports RecipientImport[]
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String?
  name            String?
  isPlatformAdmin Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships Membership[]
  campaigns   Campaign[]
}

model Membership {
  id                String    @id @default(uuid())
  role              Role
  organizationId    String
  userId            String
  inviteToken       String?   @unique // SHA-256 hashed token for invite accept links
  inviteTokenExpiry DateTime?
  acceptedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
}

model Vendor {
  id                  String                 @id @default(uuid())
  name                String
  contact             String
  fulfillmentType     VendorFulfillmentType
  serviceablePincodes Json? // Array of strings or regions
  cutoffDates         Json? // E.g., { "Diwali": "2026-11-01" }
  payoutDetails       Json?
  status              VendorStatus           @default(ACTIVE)
  onboardingStatus    VendorOnboardingStatus @default(SHELL_CREATED)
  defaultMarkupBps    Int?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  products    Product[]
  vendorUsers VendorUser[]
}

model VendorUser {
  id                String           @id @default(cuid())
  vendorId          String
  vendor            Vendor           @relation(fields: [vendorId], references: [id])
  email             String
  passwordHash      String
  status            VendorUserStatus @default(INVITED) // INVITED | ACTIVE | DISABLED
  mustResetPassword Boolean          @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([vendorId, email])
}

model VendorInvite {
  id        String    @id @default(cuid())
  vendorId  String
  email     String
  tokenHash String    @unique // SHA-256
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model HsnCode {
  code              String @id
  description       String
  defaultGstRateBps Int
}

model Product {
  id                    String           @id @default(uuid())
  vendorId              String
  title                 String
  description           String
  whatsInside           String? // Rich text
  images                Json             @default("[]") // JSON array of { url, width, height, uploadedAt }
  category              String?
  attributes            Json?
  status                ProductStatus    @default(DRAFT)
  createdByVendorUserId String?
  moderationStatus      ModerationStatus @default(PUBLISHED)
  validationErrors      Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  vendor      Vendor            @relation(fields: [vendorId], references: [id])
  variants    Variant[]
  campaigns   CampaignProduct[]
  collections CollectionItem[]
}

model Variant {
  id                          String   @id @default(uuid())
  productId                   String
  sku                         String   @unique
  title                       String
  priceCents                  Int
  costCents                   Int
  hsnCode                     String?
  gstRateBps                  Int // Basis points (e.g., 1800 for 18%)
  isDigital                   Boolean  @default(false)
  stockQty                    Int      @default(0)
  priceCentsOverriddenByAdmin Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id])
  orders     Order[]
  recipients Recipient[]
}

model Collection {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CollectionItem[]
}

model CollectionItem {
  id           String   @id @default(uuid())
  collectionId String
  productId    String
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([collectionId, productId])
}

model Campaign {
  id                      String         @id @default(uuid())
  organizationId          String
  createdById             String
  name                    String
  mode                    CampaignMode
  budgetCentsPerRecipient Int? // Null if SINGLE
  messageTemplate         String
  branding                Json           @default("{}") // logo, accentColor
  status                  CampaignStatus @default(DRAFT)
  expiresAt               DateTime
  serviceFeeBps           Int            @default(500) // 5%
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  createdBy        User              @relation(fields: [createdById], references: [id])
  products         CampaignProduct[]
  recipients       Recipient[]
  orders           Order[]
  recipientImports RecipientImport[]
}

model CampaignProduct {
  id               String   @id @default(uuid())
  campaignId       String
  productId        String
  variantSnapshots Json? // { variantId: { sku, title, priceCents, hsnCode, gstRateBps, isDigital } }
  createdAt        DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([campaignId, productId])
}

model Recipient {
  id                String          @id @default(uuid())
  campaignId        String
  name              String
  email             String
  phone             String?
  tokenHash         String          @unique
  status            RecipientStatus @default(INVITED)
  address           String? // Encrypted at rest
  redeemedVariantId String?
  redeemedAt        DateTime?
  reminderCount     Int             @default(0)
  optOutAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  campaign        Campaign @relation(fields: [campaignId], references: [id])
  redeemedVariant Variant? @relation(fields: [redeemedVariantId], references: [id])
  order           Order?

  @@unique([campaignId, email])
  @@index([campaignId, status])
}

model RecipientImport {
  id             String       @id @default(uuid())
  organizationId String
  campaignId     String
  status         ImportStatus @default(PENDING)
  totalRows      Int          @default(0)
  processedRows  Int          @default(0)
  errorReport    Json? // e.g. [{ row: 2, error: "Invalid email" }]
  rawContent     String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  campaign     Campaign     @relation(fields: [campaignId], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  organizationId String
  campaignId     String
  recipientId    String      @unique
  variantId      String
  priceCents     Int
  status         OrderStatus @default(PENDING)
  vendorOrderRef String?
  idempotencyKey String      @unique
  exceptionNote  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  campaign     Campaign     @relation(fields: [campaignId], references: [id])
  recipient    Recipient    @relation(fields: [recipientId], references: [id])
  variant      Variant      @relation(fields: [variantId], references: [id])
  shipment     Shipment?

  @@index([organizationId, status, createdAt])
}

model Shipment {
  id             String    @id @default(uuid())
  orderId        String    @unique
  carrier        String?
  trackingNumber String?
  trackingUrl    String?
  events         Json?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model Wallet {
  id             String   @id @default(uuid())
  organizationId String   @unique
  balanceCents   BigInt   @default(0)
  heldCents      BigInt   @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  ledger       WalletLedger[]
}

/// Ledger semantics:
/// - HOLD / HOLD_RELEASE move `heldCents`
/// - TOPUP / CHARGE / REFUND / ADJUSTMENT move `balanceCents`
model WalletLedger {
  id                String          @id @default(uuid())
  walletId          String
  amountCents       BigInt // Signed
  type              LedgerEntryType
  referenceType     String? // e.g., 'ORDER', 'CAMPAIGN', 'PAYMENT'
  referenceId       String?
  balanceAfterCents BigInt
  heldAfterCents    BigInt
  createdAt         DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
}

model Payment {
  id             String          @id @default(uuid())
  organizationId String
  provider       PaymentProvider
  providerRef    String?
  amountCents    BigInt
  status         PaymentStatus   @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model WebhookEvent {
  id          String          @id @default(uuid())
  provider    PaymentProvider
  eventId     String          @unique
  processedAt DateTime        @default(now())
}

model ProformaInvoice {
  id             String   @id @default(uuid())
  number         String   @unique
  organizationId String
  pdfUrl         String?
  totals         Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model Invoice {
  id             String   @id @default(uuid())
  number         String   @unique
  organizationId String
  pdfUrl         String?
  gstBreakdown   Json // per-line HSN, taxable value, CGST/SGST/IGST
  totals         Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  actorId        String // userId or 'SYSTEM'
  action         String
  targetType     String
  targetId       String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
}

model NotificationLog {
  id            String              @id @default(uuid())
  recipientType String // e.g., 'USER', 'RECIPIENT'
  recipientId   String?
  channel       NotificationChannel
  template      String
  status        NotificationStatus  @default(SENT)
  providerRef   String?
  createdAt     DateTime            @default(now())
}
